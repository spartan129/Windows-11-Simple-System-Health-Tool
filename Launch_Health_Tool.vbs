objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# LOG HELPERS  (UI thread only - called from timer tick)"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "function Append-Log([string]$Text, [Drawing.Color]$Color) {"
objFile.WriteLine "    $logBox.SelectionStart  = $logBox.TextLength"
objFile.WriteLine "    $logBox.SelectionLength = 0"
objFile.WriteLine "    $logBox.SelectionColor  = $Color"
objFile.WriteLine "    $logBox.AppendText($Text + ""`n"")"
objFile.WriteLine "    $logBox.SelectionColor  = $cFG"
objFile.WriteLine "    $logBox.ScrollToCaret()"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "function Show-QueuedMessage([string]$Msg) {"
objFile.WriteLine "    if ($Msg.Length -ge 2 -and $Msg[1] -eq '|') {"
objFile.WriteLine "        $col = switch ($Msg[0]) {"
objFile.WriteLine "            'H' { $cCyan  }"
objFile.WriteLine "            'P' { $cGreen }"
objFile.WriteLine "            'F' { $cRed   }"
objFile.WriteLine "            'E' { $cRed   }"
objFile.WriteLine "            'D' { $cDim   }"
objFile.WriteLine "            default { $cFG }"
objFile.WriteLine "        }"
objFile.WriteLine "        Append-Log $Msg.Substring(2) $col"
objFile.WriteLine "    } else {"
objFile.WriteLine "        Append-Log $Msg $cFG"
objFile.WriteLine "    }"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# POLLING TIMER - drains queue, detects task completion"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$pollingTimer          = New-Object Windows.Forms.Timer"
objFile.WriteLine "$pollingTimer.Interval = 80"
objFile.WriteLine "$pollingTimer.Add_Tick({"
objFile.WriteLine "    $msg = """""
objFile.WriteLine "    while ($script:MsgQueue.TryDequeue([ref]$msg)) { Show-QueuedMessage $msg }"
objFile.WriteLine ""
objFile.WriteLine "    if ($script:IsBusy -and $null -ne $script:Handle -and $script:Handle.IsCompleted) {"
objFile.WriteLine "        # Drain any remaining messages"
objFile.WriteLine "        while ($script:MsgQueue.TryDequeue([ref]$msg)) { Show-QueuedMessage $msg }"
objFile.WriteLine ""
objFile.WriteLine "        if ($script:PSInst.HadErrors) {"
objFile.WriteLine "            Append-Log """" $cFG"
objFile.WriteLine "            Append-Log ""[!] One or more steps reported errors - see report for details."" $cRed"
objFile.WriteLine "        } else {"
objFile.WriteLine "            Append-Log """" $cFG"
objFile.WriteLine "            Append-Log ""Done."" $cGreen"
objFile.WriteLine "        }"
objFile.WriteLine "        Append-Log ""Report: $ReportPath"" $cDim"
objFile.WriteLine "        Append-Log (""-"" * 68) $cSep"
objFile.WriteLine ""
objFile.WriteLine "        # Cleanup"
objFile.WriteLine "        try { $script:PSInst.Dispose()                          } catch {}"
objFile.WriteLine "        try { $script:RS.Close(); $script:RS.Dispose()          } catch {}"
objFile.WriteLine "        $script:PSInst  = $null"
objFile.WriteLine "        $script:RS      = $null"
objFile.WriteLine "        $script:Handle  = $null"
objFile.WriteLine "        $script:IsBusy  = $false"
objFile.WriteLine ""
objFile.WriteLine "        $statusLabel.Text = ""Ready"""
objFile.WriteLine "        foreach ($b in $script:AllButtons) { $b.Enabled = $true }"
objFile.WriteLine "    }"
objFile.WriteLine "})"
objFile.WriteLine "$pollingTimer.Start()"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# FORM CLOSING"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$form.Add_FormClosing({"
objFile.WriteLine "    $pollingTimer.Stop()"
objFile.WriteLine "    if ($script:PSInst) { try { $script:PSInst.Dispose()               } catch {} }"
objFile.WriteLine "    if ($script:RS)     { try { $script:RS.Close(); $script:RS.Dispose() } catch {} }"
objFile.WriteLine "})"
objFile.WriteLine ""
