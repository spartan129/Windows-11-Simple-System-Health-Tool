objFile.WriteLine ""
objFile.WriteLine "Add-Separator $pLeft ($yPos + 6)"
objFile.WriteLine "$yPos += 18"
objFile.WriteLine ""
objFile.WriteLine "# Open Report button"
objFile.WriteLine "$btnReport           = New-Object Windows.Forms.Button"
objFile.WriteLine "$btnReport.Text      = ""Open Report File"""
objFile.WriteLine "$btnReport.Font      = $fUI"
objFile.WriteLine "$btnReport.FlatStyle = ""Flat"""
