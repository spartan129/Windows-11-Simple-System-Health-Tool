' Simple System Health Tool - Combined Single-File Launcher
' Drop this .vbs anywhere and double-click to run.

Dim objShell, objFSO, strPS1, objFile

Set objShell = CreateObject("WScript.Shell")
Set objFSO   = CreateObject("Scripting.FileSystemObject")

' Write the embedded PS1 to a temp file
strPS1 = objFSO.GetSpecialFolder(2) & "\Simple_System_Health_Tool_GUI.ps1"
Set objFile = objFSO.CreateTextFile(strPS1, True, True)

objFile.WriteLine "#Requires -Version 5.1"
objFile.WriteLine "<#"
objFile.WriteLine ".SYNOPSIS    Simple System Health Tool - GUI Edition  v3.1"
objFile.WriteLine ".DESCRIPTION Graphical interface for common Windows maintenance tasks."
objFile.WriteLine "             Self-elevates to Administrator if needed."
objFile.WriteLine "             No compiled executables, no encoded commands."
objFile.WriteLine "#>"
objFile.WriteLine ""
objFile.WriteLine "# Catch any startup crash and show it in a popup instead of a vanishing console"
objFile.WriteLine "trap {"
objFile.WriteLine "    try {"
objFile.WriteLine "        Add-Type -AssemblyName System.Windows.Forms -ErrorAction SilentlyContinue"
objFile.WriteLine "        [System.Windows.Forms.MessageBox]::Show("
objFile.WriteLine "            ""Startup error:`n`n$($_.Exception.Message)`n`n$($_.InvocationInfo.PositionMessage)"","
objFile.WriteLine "            ""Simple System Health Tool - Error"", ""OK"", ""Error"") | Out-Null"
objFile.WriteLine "    } catch {"
objFile.WriteLine "        Write-Host ""FATAL: $($_.Exception.Message)"" -ForegroundColor Red"
objFile.WriteLine "    }"
objFile.WriteLine "    exit 1"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "Add-Type -AssemblyName System.Windows.Forms"
objFile.WriteLine "Add-Type -AssemblyName System.Drawing"
objFile.WriteLine "[System.Windows.Forms.Application]::EnableVisualStyles()"
objFile.WriteLine "[System.Windows.Forms.Application]::SetCompatibleTextRenderingDefault($false)"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# SELF-ELEVATE"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$principal = [Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()"
objFile.WriteLine "if (-not $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {"
objFile.WriteLine "    $psPath = if ($PSCommandPath) { $PSCommandPath } else { $MyInvocation.MyCommand.Definition }"
objFile.WriteLine "    Start-Process powershell.exe `"
objFile.WriteLine "        -ArgumentList ""-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `""$psPath`"""" `"
objFile.WriteLine "        -Verb RunAs `"
objFile.WriteLine "        -WindowStyle Hidden"
objFile.WriteLine "    exit 0"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# PATHS"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$ScriptDir  = if ($PSScriptRoot -and $PSScriptRoot -ne '') {"
objFile.WriteLine "    $PSScriptRoot"
objFile.WriteLine "} else {"
objFile.WriteLine "    Split-Path -Parent $MyInvocation.MyCommand.Definition"
objFile.WriteLine "}"
objFile.WriteLine "if (-not $ScriptDir -or -not (Test-Path $ScriptDir)) { $ScriptDir = $env:TEMP }"
objFile.WriteLine "$ReportPath = Join-Path $ScriptDir ""$($env:COMPUTERNAME)SystemHealth.txt"""
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# INTER-THREAD MESSAGE QUEUE"
objFile.WriteLine "# Message format: single-char type + ""|"" + text"
objFile.WriteLine "#   H=header (cyan)  P=pass (green)  F=fail (red)  E=error (red)"
objFile.WriteLine "#   D=detail (dim)   I=info (white)"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$script:MsgQueue = [System.Collections.Concurrent.ConcurrentQueue[string]]::new()"
objFile.WriteLine "$script:IsBusy   = $false"
objFile.WriteLine "$script:PSInst   = $null"
objFile.WriteLine "$script:RS       = $null"
objFile.WriteLine "$script:Handle   = $null"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# REPORT  (called on UI thread only)"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "function Initialize-Report {"
objFile.WriteLine "    if (Test-Path $ReportPath) { return }"
objFile.WriteLine "    $sep  = ""="" * 79"
objFile.WriteLine "    $rows = [System.Collections.Generic.List[string]]::new()"
objFile.WriteLine "    $rows.Add($sep)"
objFile.WriteLine "    $rows.Add(""$($env:COMPUTERNAME) System Health Report"")"
objFile.WriteLine "    $rows.Add($sep)"
objFile.WriteLine "    $rows.Add(""Computer Name : $($env:COMPUTERNAME)"")"
objFile.WriteLine "    try {"
objFile.WriteLine "        $reg = Get-ItemProperty ""HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion"" -EA Stop"
objFile.WriteLine "        $rows.Add(""Windows       : $($reg.ProductName)"")"
objFile.WriteLine "        $rows.Add(""Version       : $($reg.DisplayVersion)"")"
objFile.WriteLine "        $rows.Add(""Build         : $($reg.CurrentBuild)"")"
objFile.WriteLine "    } catch {}"
objFile.WriteLine "    try {"
objFile.WriteLine "        $sn = (Get-CimInstance Win32_BIOS -EA Stop).SerialNumber.Trim()"
objFile.WriteLine "        if ($sn -and $sn -notmatch ""O\.E\.M|^\s*$"") { $rows.Add(""Serial Number : $sn"") }"
objFile.WriteLine "    } catch {}"
objFile.WriteLine "    try {"
objFile.WriteLine "        $pk = (Get-CimInstance -Query ""SELECT OA3xOriginalProductKey FROM SoftwareLicensingService"" -EA Stop).OA3xOriginalProductKey"
objFile.WriteLine "        if ($pk) { $rows.Add(""License Key   : $pk"") } else { $rows.Add(""License Key   : Not found or not exposed."") }"
objFile.WriteLine "    } catch { $rows.Add(""License Key   : Not found or not exposed."") }"
objFile.WriteLine "    $rows.Add(""Created       : $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')"")"
objFile.WriteLine "    $rows.Add($sep)"
objFile.WriteLine "    $rows.Add("""")"
objFile.WriteLine "    [IO.File]::WriteAllLines($ReportPath, $rows, [Text.Encoding]::UTF8)"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# BACKGROUND TASK SCRIPT"
objFile.WriteLine "# Variables injected via runspace SetVariable:"
objFile.WriteLine "#   $Queue       ConcurrentQueue[string]"
objFile.WriteLine "#   $ReportPath  string"
objFile.WriteLine "#   $TaskName    string"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "$BackgroundScript = @'"
objFile.WriteLine "function Write-Section([string]$Title) {"
objFile.WriteLine "    $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'"
objFile.WriteLine "    [IO.File]::AppendAllText($ReportPath,"
objFile.WriteLine "        ""`n$(""-"" * 79)`n[$ts] $Title`n"", [Text.Encoding]::UTF8)"
objFile.WriteLine "}"
objFile.WriteLine "function Write-Result([string]$Result, [int]$Code, [string]$Msg) {"
objFile.WriteLine "    [IO.File]::AppendAllText($ReportPath,"
objFile.WriteLine "        ""Result    : $Result`nExit Code : $Code`nMessage   : $Msg`n"","
objFile.WriteLine "        [Text.Encoding]::UTF8)"
objFile.WriteLine "}"
objFile.WriteLine "function Invoke-Step([string]$Title, [string]$CmdLine) {"
objFile.WriteLine "    Write-Section $Title"
objFile.WriteLine "    $Queue.Enqueue(""I|  $Title"")"
objFile.WriteLine "    try {"
objFile.WriteLine "        $si = New-Object System.Diagnostics.ProcessStartInfo"
objFile.WriteLine "        $si.FileName               = ""cmd.exe"""
objFile.WriteLine "        $si.Arguments              = ""/c $CmdLine"""
objFile.WriteLine "        $si.RedirectStandardOutput = $true"
objFile.WriteLine "        $si.RedirectStandardError  = $true"
objFile.WriteLine "        $si.UseShellExecute        = $false"
objFile.WriteLine "        $si.CreateNoWindow         = $true"
objFile.WriteLine ""
objFile.WriteLine "        $proc = [System.Diagnostics.Process]::Start($si)"
objFile.WriteLine "        $out  = $proc.StandardOutput.ReadToEnd()"
objFile.WriteLine "        $err  = $proc.StandardError.ReadToEnd()"
objFile.WriteLine "        $proc.WaitForExit()"
objFile.WriteLine "        $rc   = $proc.ExitCode"
objFile.WriteLine ""
objFile.WriteLine "        $combined = ($out + $err).Trim()"
objFile.WriteLine "        foreach ($ln in ($combined -split ""`r?`n"")) {"
objFile.WriteLine "            if ($ln.Trim()) { $Queue.Enqueue(""D|    $ln"") }"
objFile.WriteLine "        }"
objFile.WriteLine "        $last = ($combined -split ""`r?`n"" |"
objFile.WriteLine "                 Where-Object { $_.Trim() } | Select-Object -Last 1)"
objFile.WriteLine "        if (-not $last) { $last = ""(no output)"" }"
objFile.WriteLine ""
objFile.WriteLine "        $res = if ($rc -eq 0) { ""PASS"" } else { ""FAIL"" }"
objFile.WriteLine "        Write-Result $res $rc $last"
objFile.WriteLine "        if ($rc -eq 0) { $Queue.Enqueue(""P|    [PASS] Exit code: $rc"") }"
objFile.WriteLine "        else           { $Queue.Enqueue(""F|    [FAIL] Exit code: $rc"") }"
objFile.WriteLine "        $Queue.Enqueue(""I|"")"
objFile.WriteLine "    } catch {"
objFile.WriteLine "        Write-Result ""FAIL"" -1 $_.Exception.Message"
objFile.WriteLine "        $Queue.Enqueue(""E|    [ERROR] $($_.Exception.Message)"")"
objFile.WriteLine "        $Queue.Enqueue(""I|"")"
objFile.WriteLine "    }"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "switch ($TaskName) {"
objFile.WriteLine "    ""PrintSpooler"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|-- Reset Print Spooler ------------------------------------------------------"")"
objFile.WriteLine "        Invoke-Step ""Stop Print Spooler""  ""net stop spooler"""
objFile.WriteLine "        $q = ""$env:SystemRoot\System32\spool\PRINTERS"""
objFile.WriteLine "        if (Test-Path $q) {"
objFile.WriteLine "            Remove-Item ""$q\*"" -Force -ErrorAction SilentlyContinue"
objFile.WriteLine "            $Queue.Enqueue(""D|    Print queue cleared."")"
objFile.WriteLine "        }"
objFile.WriteLine "        Invoke-Step ""Start Print Spooler"" ""net start spooler"""
objFile.WriteLine "    }"
objFile.WriteLine "    ""NetworkReset"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|-- Reset Network -----------------------------------------------------------"")"
objFile.WriteLine "        Invoke-Step ""Disable Physical Adapters"" 'wmic path win32_networkadapter where ""NetEnabled=true and PhysicalAdapter=true"" call disable'"
objFile.WriteLine "        Invoke-Step ""Enable Physical Adapters""  'wmic path win32_networkadapter where ""PhysicalAdapter=true"" call enable'"
objFile.WriteLine "        Invoke-Step ""Release and Renew IP""       ""ipconfig /release & ipconfig /renew"""
objFile.WriteLine "        Invoke-Step ""Flush DNS Cache""            ""ipconfig /flushdns"""
objFile.WriteLine "        Invoke-Step ""Reset Winsock Catalog""      ""netsh winsock reset"""
objFile.WriteLine "        Invoke-Step ""Reset TCP/IP Stack""         ""netsh int ip reset"""
objFile.WriteLine "    }"
objFile.WriteLine "    ""SystemCheck"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|-- System Check ------------------------------------------------------------"")"
objFile.WriteLine "        $Queue.Enqueue(""I|  Note: DISM RestoreHealth may take 10-20 minutes."")"
objFile.WriteLine "        Invoke-Step ""DISM RestoreHealth"" ""DISM /Online /Cleanup-Image /RestoreHealth"""
objFile.WriteLine "        Invoke-Step ""SFC Scan""           ""sfc /scannow"""
objFile.WriteLine "        Invoke-Step ""CHKDSK C: Scan""    ""chkdsk C: /scan"""
objFile.WriteLine "    }"
objFile.WriteLine "    ""WindowsUpdate"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|-- Reset Windows Update -----------------------------------------------------"")"
objFile.WriteLine "        $cmd = ""net stop wuauserv & net stop bits & net stop cryptsvc & net stop msiserver & "" +"
objFile.WriteLine "               ""ren C:\Windows\SoftwareDistribution SoftwareDistribution.old 2>nul & "" +"
objFile.WriteLine "               ""ren C:\Windows\System32\catroot2 catroot2.old 2>nul & "" +"
objFile.WriteLine "               ""net start msiserver & net start cryptsvc & net start bits & net start wuauserv"""
objFile.WriteLine "        Invoke-Step ""Reset Windows Update"" $cmd"
objFile.WriteLine "    }"
objFile.WriteLine "    ""MemoryDiag"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|-- Windows Memory Diagnostic -----------------------------------------------"")"
objFile.WriteLine "        $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'"
objFile.WriteLine "        [IO.File]::AppendAllText($ReportPath,"
objFile.WriteLine "            ""`n$(""-""*79)`n[$ts] Windows Memory Diagnostic`n"", [Text.Encoding]::UTF8)"
objFile.WriteLine "        try {"
objFile.WriteLine "            Start-Process mdsched.exe"
objFile.WriteLine "            [IO.File]::AppendAllText($ReportPath,"
objFile.WriteLine "                ""Result    : PASS`nExit Code : 0`nMessage   : Launched.`n"","
objFile.WriteLine "                [Text.Encoding]::UTF8)"
objFile.WriteLine "            $Queue.Enqueue(""P|    [PASS] Windows Memory Diagnostic launched."")"
objFile.WriteLine "            $Queue.Enqueue(""D|    You can schedule the test from the dialog that appeared."")"
objFile.WriteLine "        } catch {"
objFile.WriteLine "            [IO.File]::AppendAllText($ReportPath,"
objFile.WriteLine "                ""Result    : FAIL`nExit Code : -1`nMessage   : $($_.Exception.Message)`n"","
objFile.WriteLine "                [Text.Encoding]::UTF8)"
objFile.WriteLine "            $Queue.Enqueue(""E|    [ERROR] $($_.Exception.Message)"")"
objFile.WriteLine "        }"
objFile.WriteLine "        $Queue.Enqueue(""I|"")"
objFile.WriteLine "    }"
objFile.WriteLine "    ""UnFuck"" {"
objFile.WriteLine "        $Queue.Enqueue(""H|== UnFuck - Full Repair Sequence ==========================================="")"
objFile.WriteLine "        $Queue.Enqueue(""I|  This may take 20-45 minutes. The window stays responsive throughout."")"
objFile.WriteLine "        $Queue.Enqueue(""I|"")"
objFile.WriteLine "        Invoke-Step ""DISM CheckHealth""   ""DISM /Online /Cleanup-Image /CheckHealth"""
objFile.WriteLine "        Invoke-Step ""DISM ScanHealth""    ""DISM /Online /Cleanup-Image /ScanHealth"""
objFile.WriteLine "        Invoke-Step ""DISM RestoreHealth"" ""DISM /Online /Cleanup-Image /RestoreHealth"""
objFile.WriteLine "        Invoke-Step ""SFC Scan""           ""sfc /scannow"""
objFile.WriteLine "        Invoke-Step ""CHKDSK C: Scan""    ""chkdsk C: /scan"""
objFile.WriteLine "        Invoke-Step ""Component Cleanup""  ""DISM /Online /Cleanup-Image /StartComponentCleanup"""
objFile.WriteLine "        $upd = ""net stop wuauserv & net stop bits & net stop cryptsvc & net stop msiserver & "" +"
objFile.WriteLine "               ""ren C:\Windows\SoftwareDistribution SoftwareDistribution.old 2>nul & "" +"
objFile.WriteLine "               ""ren C:\Windows\System32\catroot2 catroot2.old 2>nul & "" +"
objFile.WriteLine "               ""net start msiserver & net start cryptsvc & net start bits & net start wuauserv"""
objFile.WriteLine "        Invoke-Step ""Reset Windows Update"" $upd"
objFile.WriteLine "        Invoke-Step ""Stop Print Spooler""  ""net stop spooler"""
objFile.WriteLine "        $q = ""$env:SystemRoot\System32\spool\PRINTERS"""
objFile.WriteLine "        if (Test-Path $q) {"
objFile.WriteLine "            Remove-Item ""$q\*"" -Force -ErrorAction SilentlyContinue"
objFile.WriteLine "            $Queue.Enqueue(""D|    Print queue cleared."")"
objFile.WriteLine "        }"
objFile.WriteLine "        Invoke-Step ""Start Print Spooler"" ""net start spooler"""
objFile.WriteLine "        Invoke-Step ""Flush DNS""           ""ipconfig /flushdns"""
objFile.WriteLine "        Invoke-Step ""Reset Winsock""       ""netsh winsock reset"""
objFile.WriteLine "        Invoke-Step ""Reset TCP/IP""        ""netsh int ip reset"""
objFile.WriteLine "    }"
objFile.WriteLine "}"
objFile.WriteLine "'@"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "# START TASK  (UI thread)"
objFile.WriteLine "# =============================================================================="
objFile.WriteLine "function Start-Task([string]$TaskName) {"
objFile.WriteLine "    if ($script:IsBusy) {"
objFile.WriteLine "        [Windows.Forms.MessageBox]::Show("
objFile.WriteLine "            ""An operation is already running.`nPlease wait for it to complete."","
objFile.WriteLine "            ""Busy"", ""OK"", ""Warning"") | Out-Null"
objFile.WriteLine "        return"
objFile.WriteLine "    }"
objFile.WriteLine "    Initialize-Report"
objFile.WriteLine ""
objFile.WriteLine "    $script:IsBusy    = $true"
objFile.WriteLine "    $statusLabel.Text = ""Running: $TaskName ..."""
objFile.WriteLine "    foreach ($b in $script:AllButtons) { $b.Enabled = $false }"
objFile.WriteLine ""
objFile.WriteLine "    $script:RS = [RunspaceFactory]::CreateRunspace()"
objFile.WriteLine "    $script:RS.ApartmentState = ""STA"""
objFile.WriteLine "    $script:RS.ThreadOptions  = ""ReuseThread"""
objFile.WriteLine "    $script:RS.Open()"
objFile.WriteLine "    $script:RS.SessionStateProxy.SetVariable(""Queue"",      $script:MsgQueue)"
objFile.WriteLine "    $script:RS.SessionStateProxy.SetVariable(""ReportPath"", $ReportPath)"
objFile.WriteLine "    $script:RS.SessionStateProxy.SetVariable(""TaskName"",   $TaskName)"
objFile.WriteLine ""
objFile.WriteLine "    $script:PSInst = [PowerShell]::Create()"
objFile.WriteLine "    $script:PSInst.Runspace = $script:RS"
objFile.WriteLine "    [void]$script:PSInst.AddScript($BackgroundScript)"
objFile.WriteLine "    $script:Handle = $script:PSInst.BeginInvoke()"
objFile.WriteLine "}"
objFile.WriteLine ""
objFile.WriteLine "# =============================================================================="
